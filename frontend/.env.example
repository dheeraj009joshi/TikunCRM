# Frontend Environment Variables

# API Configuration
# Backend API base URL
# For local development: http://localhost:8000/api/v1
# For production: https://api.tikuncrm.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# WhatsApp Service WebSocket URL
# For local development: ws://localhost:3001/ws
# For production: wss://your-domain.com:3001/ws or wss://wp.your-domain.com/ws
# If not set, will auto-detect based on current hostname
# NEXT_PUBLIC_WHATSAPP_WS_URL=ws://localhost:3001/ws

# Application Configuration
NEXT_PUBLIC_APP_NAME=TikunCRM
NEXT_PUBLIC_APP_ENV=development

# Optional: Feature Flags
# NEXT_PUBLIC_ENABLE_ANALYTICS=false
# NEXT_PUBLIC_ENABLE_DEBUG_MODE=false
