# TikunCRM Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# Database Configuration
# ===========================================
POSTGRES_USER=tikuncrm
POSTGRES_PASSWORD=change_this_to_a_secure_password
POSTGRES_DB=tikuncrm
DATABASE_URL=postgresql+asyncpg://tikuncrm:change_this_to_a_secure_password@db:5432/tikuncrm

# ===========================================
# Redis Configuration
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# Security
# ===========================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here

# ===========================================
# CORS Configuration
# ===========================================
CORS_ORIGINS=https://tikuncrm.com,https://www.tikuncrm.com

# ===========================================
# Frontend URLs (used during build)
# ===========================================
NEXT_PUBLIC_API_URL=https://api.tikuncrm.com/api/v1
NEXT_PUBLIC_WS_URL=wss://api.tikuncrm.com
NEXT_PUBLIC_APP_URL=https://tikuncrm.com

# ===========================================
# Twilio Configuration (SMS/Calls)
# ===========================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===========================================
# SendGrid Configuration (Email)
# ===========================================
SENDGRID_API_KEY=

# ===========================================
# Firebase Configuration (Push Notifications)
# ===========================================
# Paste your Firebase service account JSON as a single line
FIREBASE_CREDENTIALS=

# ===========================================
# AWS S3 Configuration (File Uploads)
# ===========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=tikuncrm-uploads

# ===========================================
# WhatsApp Business API (optional)
# ===========================================
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
